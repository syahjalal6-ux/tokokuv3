{
  "redirects": [
    { "source": "/toko/:slug", "destination": "/:slug", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/:slug",
      "has": [
        {
          "type": "query",
          "key": "produk"
        }
      ],
      "destination": "/api/og?slug=:slug&produk={produk}"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
