# ================================================
# TOKOKU — Environment Variables
# Copy file ini menjadi .env.local dan isi nilainya
# ================================================

# Google Apps Script Web App URL
# Dapatkan dari: script.google.com → Deploy → Web App URL
VITE_GAS_URL=https://script.google.com/macros/s/GANTI_DEPLOYMENT_ID/exec

# Google OAuth Client ID
# Dapatkan dari: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=GANTI_CLIENT_ID.apps.googleusercontent.com

# Nomor WhatsApp Admin (format: 628xxx tanpa + atau spasi)
VITE_ADMIN_WA=628123456789

# URL aplikasi (untuk generate storefront URL)
VITE_APP_URL=https://tokoku.vercel.app
